NODE_ENV=test

HTTP_PORT=4200
HTTP_HOST=localhost
HTTP_PREFIX=api/

### DATABASE
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5433
DB_DATABASE=voting_system_test
DB_USERNAME=postgres
DB_PASSWORD=pass
DB_LOGGING=false
DB_MIGRATIONS_TABLE_NAME=database_migrations

#REDIS
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=pass123

# COOKIES
COOKIES_SECRET=cookies-secret

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

#Swagger
ENABLE_SWAGGER=true

#CLIENT
CORS_ORIGINS=http://localhost:3000



# чтобы запустить проект в тестовом режиме
# 1) docker-compose --env-file .env.test up -d
# 2) yarn migration:run:test